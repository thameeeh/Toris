<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="Master-Root" style="flex-grow: 1; picking-mode: Ignore;">
        <ui:VisualElement name="Layer_Windows" style="position: absolute; left: 0; top: 0; right: 0; flex-direction: row; justify-content: space-between; picking-mode: Ignore; width: 100%; height: 80%; flex-grow: 1;">
            <ui:VisualElement name="Left_Zone" style="width: 30%; height: 100%; picking-mode: Ignore; flex-grow: 1; max-width: 30%; background-color: rgba(219, 214, 0, 0.15);"/>
            <ui:VisualElement name="Right_Zone" style="width: 30%; height: 100%; picking-mode: Ignore; flex-grow: 1; background-color: rgba(64, 255, 134, 0.09); max-width: 30%; max-height: 100%; flex-direction: column;"/>
        </ui:VisualElement>
        <ui:VisualElement name="Layer_HUD" style="position: absolute; left: 0; bottom: 0; right: 1; height: 20%; justify-content: flex-end; picking-mode: Ignore; background-color: rgba(36, 36, 36, 0.33);"/>
    </ui:VisualElement>
</ui:UXML>
