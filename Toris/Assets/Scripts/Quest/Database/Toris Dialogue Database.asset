        destinationDialogueID: 6
        isConnector: 0
        priority: 2
      conditionsString: 
      userScript: 
      onExecute:
        m_PersistentCalls:
          m_Calls: []
      canvasRect:
        serializedVersion: 2
        x: 260
        y: 180
        width: 160
        height: 30
    - id: 6
      fields:
      - title: Title
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Description
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Actor
        value: 2
        type: 5
        typeString: CustomFieldType_Actor
      - title: Conversant
        value: 1
        type: 5
        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: Well, nevertheless, you will need help if you plan to survive out here.
          The outside world is not exactly pleasant, but it is not dead either.
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      conversationID: 1
      isRoot: 0
      isGroup: 0
