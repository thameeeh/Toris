        type: 5
        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: I see. Not everyone wants to reveal their secrets at the first sight of
          humanity. That is fine. Out here, people are allowed to keep things to
          themselves.
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      conversationID: 1
      isRoot: 0
      isGroup: 0
